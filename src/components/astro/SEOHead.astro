---
import type { Locale } from '../../lib/i18n';
import { locales, localePath } from '../../lib/i18n';

interface AlternatePath {
  locale: Locale;
  path: string;
}

interface Props {
  title: string;
  description: string;
  locale: Locale;
  canonicalPath: string;
  alternatePaths?: AlternatePath[];
  ogImage?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  modifiedDate?: string;
  schema?: Record<string, unknown>;
}

const {
  title,
  description,
  locale,
  canonicalPath,
  alternatePaths,
  ogImage = '/images/og-default.jpg',
  type = 'website',
  publishedDate,
  modifiedDate,
  schema,
} = Astro.props;

const site = Astro.site?.origin ?? 'https://www.feel-like-dancing.com';
const canonicalURL = `${site}${localePath(locale, canonicalPath)}`;
const ogImageURL = ogImage.startsWith('http') ? ogImage : `${site}${ogImage}`;

const hreflangLinks = alternatePaths
  ? alternatePaths.map(({ locale: loc, path }) => ({
      locale: loc,
      href: `${site}${localePath(loc, path)}`,
    }))
  : locales.map((loc) => ({
      locale: loc,
      href: `${site}${localePath(loc, canonicalPath)}`,
    }));

const defaultSchema = {
  '@context': 'https://schema.org',
  '@type': type === 'article' ? 'Article' : 'WebSite',
  name: title,
  description,
  url: canonicalURL,
  inLanguage: locale,
  ...(type === 'article' && publishedDate ? { datePublished: publishedDate } : {}),
  ...(type === 'article' && modifiedDate ? { dateModified: modifiedDate } : {}),
  publisher: {
    '@type': 'Organization',
    name: 'Feel Like Dancing',
    url: site,
  },
};

const jsonLd = schema ?? defaultSchema;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

{hreflangLinks.map(({ locale: loc, href }) => (
  <link rel="alternate" hreflang={loc} href={href} />
))}
<link rel="alternate" hreflang="x-default" href={hreflangLinks[0].href} />

<meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:locale" content={locale === 'en' ? 'en_US' : 'es_MX'} />
<meta property="og:site_name" content="Feel Like Dancing" />
{publishedDate && <meta property="article:published_time" content={publishedDate} />}
{modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
