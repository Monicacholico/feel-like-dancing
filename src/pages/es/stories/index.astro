---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import StoryCard from '../../../components/astro/StoryCard.astro';
import { t } from '../../../lib/i18n';

const locale = 'es' as const;

const stories = [
  {
    title: 'La evolución del ballet a través de cinco siglos',
    description: 'Desde las cortes del Renacimiento italiano hasta el escenario moderno — un recorrido visual interactivo por 500 años de ballet clásico.',
    slug: 'evolucion-del-ballet',
    date: '2026-03-08',
    readingTime: 12,
  },
];
---

<BaseLayout
  title={`${t(locale, 'stories.title')} — ${t(locale, 'site.title')}`}
  description={t(locale, 'stories.subtitle')}
  locale={locale}
  canonicalPath="/stories"
>
  <section class="stories-page">
    <div class="stories-header">
      <h1>{t(locale, 'stories.title')}</h1>
      <p>{t(locale, 'stories.subtitle')}</p>
    </div>
    <div class="stories-list">
      {stories.map((story) => (
        <StoryCard {...story} locale={locale} />
      ))}
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  @use '../../../styles/variables' as *;
  @use '../../../styles/mixins' as *;

  .stories-page {
    padding-block: $spacing-lg;
  }

  .stories-header {
    @include wide-width;
    margin-bottom: $spacing-lg;

    h1 {
      margin-bottom: $spacing-xs;
    }

    p {
      font-size: 1.1rem;
      color: $color-text-light;
    }
  }

  .stories-list {
    @include wide-width;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: $spacing-md;
  }
</style>
