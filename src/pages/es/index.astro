---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoryCard from '../../components/astro/StoryCard.astro';
import { t } from '../../lib/i18n';

const locale = 'es' as const;

const stories = [
  {
    title: 'La evolución del ballet a través de cinco siglos',
    description: 'Desde las cortes del Renacimiento italiano hasta el escenario moderno — un recorrido visual interactivo por 500 años de ballet clásico.',
    slug: 'evolucion-del-ballet',
    date: '2026-03-08',
    readingTime: 12,
  },
];
---

<BaseLayout
  title={`${t(locale, 'site.title')} — ${t(locale, 'home.hero')}`}
  description={t(locale, 'site.description')}
  locale={locale}
  canonicalPath="/"
>
  <section class="hero" aria-label="Introducción">
    <div class="hero-inner">
      <h1>{t(locale, 'home.hero')}</h1>
      <p>{t(locale, 'home.heroSub')}</p>
    </div>
  </section>

  <section class="featured" aria-label={t(locale, 'home.featured')}>
    <div class="featured-inner">
      <h2>{t(locale, 'home.featured')}</h2>
      <div class="stories-grid">
        {stories.map((story) => (
          <StoryCard {...story} locale={locale} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;

  .hero {
    padding-block: $spacing-xl;
    text-align: center;
  }

  .hero-inner {
    @include content-width;

    h1 {
      margin-bottom: $spacing-sm;
    }

    p {
      font-size: 1.2rem;
      color: $color-text-light;
      max-width: 50ch;
      margin-inline: auto;
    }
  }

  .featured {
    padding-bottom: $spacing-xl;
  }

  .featured-inner {
    @include wide-width;

    h2 {
      margin-bottom: $spacing-md;
    }
  }

  .stories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: $spacing-md;
  }
</style>
