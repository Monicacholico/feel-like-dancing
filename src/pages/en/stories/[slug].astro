---
import { getCollection, render } from 'astro:content';
import StoryLayout from '../../../layouts/StoryLayout.astro';

export async function getStaticPaths() {
  const allStories = await getCollection('stories');
  const enStories = allStories.filter((s) => s.data.locale === 'en');

  return enStories.map((story) => {
    const alternate = allStories.find(
      (s) => s.data.storyId === story.data.storyId && s.data.locale === 'es',
    );
    return {
      params: { slug: story.data.slug },
      props: {
        story,
        alternatePaths: [
          { locale: 'en' as const, path: `/stories/${story.data.slug}` },
          ...(alternate
            ? [{ locale: 'es' as const, path: `/stories/${alternate.data.slug}` }]
            : []),
        ],
      },
    };
  });
}

const { story, alternatePaths } = Astro.props;
const { Content } = await render(story);
---

<StoryLayout
  title={story.data.title}
  description={story.data.description}
  locale="en"
  slug={story.data.slug}
  publishedDate={story.data.publishedDate}
  modifiedDate={story.data.modifiedDate}
  readingTime={story.data.readingTime}
  ogImage={story.data.ogImage}
  alternatePaths={alternatePaths}
>
  <Content />
</StoryLayout>
