---
import type { Locale } from '../lib/i18n';
import SEOHead from '../components/astro/SEOHead.astro';
import Nav from '../components/astro/Nav.astro';
import Footer from '../components/astro/Footer.astro';
import '../styles/global.scss';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  canonicalPath: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  modifiedDate?: string;
  schema?: Record<string, unknown>;
}

const { locale, ...seoProps } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={locale}>
  <head>
    <SEOHead locale={locale} {...seoProps} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Nav locale={locale} currentPath={currentPath} />
    <main id="main-content">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>

<style lang="scss">
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 200;
    padding: 0.5rem 1rem;
    background: #1a1a1a;
    color: #fff;
    border-radius: 0 0 4px 4px;
    font-size: 0.9rem;

    &:focus {
      top: 0;
    }
  }
</style>
